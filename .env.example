# Copy this file to .env and fill in the values.
# .env is gitignored. In production, set these in Render's dashboard instead.

# ---- Quo (SMS) ----
# Get your API key from quo.com -> Settings -> API keys
QUO_API_KEY=
# Either an E.164 phone number you own in Quo ("+15555555555") OR a Quo
# phone number id ("PN..."). Either form is accepted by the API.
QUO_FROM=

# ---- Resend (email) ----
RESEND_API_KEY=
MAIL_FROM=marina@example.com
RESEND_WEBHOOK_SECRET=

# ---- Seeded admin (optional in dev) ----
# SEED_MANAGER_EMAIL=northshoremarinaapp@gmail.com
# SEED_MANAGER_PASSWORD=
