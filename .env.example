# Copy this file to .env and fill in the values.
# .env is gitignored. In production, set these in Render's dashboard instead.

# ---- Quo (SMS) ----
# Get your API key from quo.com -> Settings -> API keys
QUO_API_KEY=
# Either an E.164 phone number you own in Quo ("+15555555555") OR a Quo
# phone number id ("PN..."). Either form is accepted by the API.
QUO_FROM=

# ---- Resend (email) ----
RESEND_API_KEY=
MAIL_FROM=marina@example.com
RESEND_WEBHOOK_SECRET=

# ---- Pushover (staff push notifications) ----
# App API token from pushover.net -> Your Applications. Each Location's
# pushover_group_key (set in db/seeds.rb or the admin UI) identifies the
# delivery group; staff user keys are entered per-user in the admin Staff form.
PUSHOVER_APP_API_KEY=

# ---- Seeded admin (optional in dev) ----
# SEED_MANAGER_EMAIL=northshoremarinaapp@gmail.com
# SEED_MANAGER_PASSWORD=
