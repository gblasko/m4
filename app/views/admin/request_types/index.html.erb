<%= render "shared/admin_nav" %>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Request types</h1>
    <%= link_to "+ New type", new_admin_request_type_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium" %>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <table class="min-w-full text-sm">
      <thead class="bg-slate-50 text-slate-600">
        <tr>
          <th class="text-left px-4 py-2 w-12">Order</th>
          <th class="text-left px-4 py-2">Name</th>
          <th class="text-left px-4 py-2">Applies to</th>
          <th class="text-left px-4 py-2">Description required</th>
          <th class="text-left px-4 py-2">Active</th>
          <th></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @types.each do |t| %>
          <tr>
            <td class="px-4 py-2">
              <%= button_to "↑", reorder_admin_request_type_path(t, direction: "up"), form: { class: "inline" }, class: "text-slate-500 hover:text-slate-900 text-xs" %>
              <%= button_to "↓", reorder_admin_request_type_path(t, direction: "down"), form: { class: "inline" }, class: "text-slate-500 hover:text-slate-900 text-xs" %>
            </td>
            <td class="px-4 py-2">
              <span class="inline-block w-3 h-3 rounded-full align-middle" style="background-color: <%= t.color %>"></span>
              <span class="font-medium text-slate-900 align-middle ml-2"><%= t.name %></span>
            </td>
            <td class="px-4 py-2"><%= t.applicable_storage_types.map(&:humanize).join(", ") %></td>
            <td class="px-4 py-2"><%= t.requires_description? ? "Yes" : "No" %></td>
            <td class="px-4 py-2"><%= t.is_active? ? "✓" : "—" %></td>
            <td class="px-4 py-2 text-right">
              <%= link_to "Edit", edit_admin_request_type_path(t), class: "text-blue-600 text-xs" %>
              <%= button_to "Remove", admin_request_type_path(t), method: :delete,
                    data: { turbo_confirm: "Remove this type?" }, form: { class: "inline" },
                    class: "text-rose-600 text-xs ml-2" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
