<% url = boat.new_record? ? admin_customer_boats_path(customer) : admin_customer_boat_path(customer, boat) %>
<%= form_with model: boat, url: url, scope: :boat, local: true,
      class: "space-y-4 bg-white rounded-xl border border-slate-200 p-6 max-w-2xl" do |f| %>
  <% if boat.errors.any? %>
    <div class="bg-rose-50 text-rose-800 p-3 rounded text-sm">
      <ul class="list-disc list-inside">
        <% boat.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Name</span>
      <%= f.text_field :name, required: true, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </label>
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Storage type</span>
      <%= f.select :storage_type, Boat::STORAGE_TYPES.map { |t| [t.humanize, t] }, {}, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </label>
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Location</span>
      <%= f.collection_select :location_id, current_organization.locations.active.order(:name), :id, :name, {}, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </label>
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Slip (optional)</span>
      <%= f.collection_select :slip_id, Slip.includes(:location).where(location_id: boat.location_id || current_organization.locations.pluck(:id)).order(:label), :id, ->(s) { "#{s.label} (#{s.slip_type})" }, { include_blank: "—" }, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </label>
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Make</span>
      <%= f.text_field :make, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </label>
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Model</span>
      <%= f.text_field :model, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </label>
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Year</span>
      <%= f.number_field :year, min: 1900, max: 2100, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </label>
    <label class="block">
      <span class="text-sm font-medium text-slate-700">Length (ft)</span>
      <%= f.number_field :length_ft, step: 0.1, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </label>
  </div>
  <label class="block">
    <span class="text-sm font-medium text-slate-700">Notes</span>
    <%= f.text_area :notes, rows: 3, class: "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" %>
  </label>
  <label class="inline-flex items-center gap-2">
    <%= f.check_box :is_active %><span class="text-sm">Active</span>
  </label>
  <div class="flex gap-3 pt-2">
    <%= f.submit (boat.new_record? ? "Add boat" : "Save"), class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium" %>
    <%= link_to "Cancel", admin_customer_path(customer), class: "text-sm text-slate-600 hover:text-slate-900" %>
  </div>
<% end %>
