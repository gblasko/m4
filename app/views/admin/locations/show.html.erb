<%= render "shared/admin_nav" %>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= @location.name %></h1>
      <p class="text-sm text-slate-500"><%= @location.address %> · <%= @location.timezone %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Manage slips", admin_location_slips_path(@location), class: "border border-slate-300 px-3 py-1.5 rounded-lg text-sm" %>
      <%= link_to "Edit", edit_admin_location_path(@location), class: "border border-slate-300 px-3 py-1.5 rounded-lg text-sm" %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
    <h2 class="font-semibold text-slate-900 mb-3">Hours</h2>
    <% day_names = %w[Sun Mon Tue Wed Thu Fri Sat] %>
    <ul class="text-sm divide-y divide-slate-100">
      <% @hours.each do |h| %>
        <li class="flex justify-between py-1.5">
          <span class="text-slate-700"><%= day_names[h.day_of_week] %></span>
          <span class="text-slate-600">
            <% if h.closed? || h.open_time.blank? %>Closed
            <% else %><%= h.open_time.strftime("%l:%M %p") %> – <%= h.close_time.strftime("%l:%M %p") %><% end %>
          </span>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h2 class="font-semibold text-slate-900 mb-3">Slip counts</h2>
    <% if @slips_by_type.any? %>
      <ul class="text-sm divide-y divide-slate-100">
        <% @slips_by_type.each do |type, count| %>
          <li class="flex justify-between py-1.5"><span><%= type.humanize %></span><span><%= count %></span></li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-slate-500">No slips yet.</p>
    <% end %>
  </div>
</div>
