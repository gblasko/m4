<%= render "shared/admin_nav" %>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Locations</h1>
    <%= link_to "+ New location", new_admin_location_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium" %>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% @locations.each do |loc| %>
      <%= link_to admin_location_path(loc), class: "block bg-white rounded-xl border border-slate-200 p-5 hover:border-blue-500" do %>
        <div class="flex items-center justify-between">
          <div>
            <div class="font-semibold text-slate-900"><%= loc.name %></div>
            <div class="text-sm text-slate-500"><%= loc.address %></div>
          </div>
          <span class="text-xs <%= loc.is_active? ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %> px-2 py-1 rounded"><%= loc.is_active? ? "Active" : "Inactive" %></span>
        </div>
        <div class="mt-3 text-sm text-slate-600">
          Soft cap: <%= loc.soft_cap_per_hour %>/hour · Slips: <%= loc.slips.count %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
