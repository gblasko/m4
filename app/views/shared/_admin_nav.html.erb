<div class="bg-slate-100 border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex gap-1 text-sm h-10 items-center overflow-x-auto">
    <% [["Overview", admin_root_path], ["Customers", admin_customers_path], ["Locations", admin_locations_path], ["Request Types", admin_request_types_path], ["Staff", admin_users_path]].each do |label, path| %>
      <%= link_to label, path,
        class: "px-3 py-1 rounded #{current_page?(path) ? 'bg-white shadow text-slate-900 font-medium' : 'text-slate-600 hover:text-slate-900'}" %>
    <% end %>
  </div>
</div>
