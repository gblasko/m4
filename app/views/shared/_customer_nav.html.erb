<% nav_items = [
  ["Boats",    root_path,     ->(p) { p == root_path || p.start_with?("/boats") }],
  ["Requests", requests_path, ->(p) { p.start_with?("/requests") }],
  ["Account",  account_path,  ->(p) { p.start_with?("/account") }]
] %>
<nav class="bg-white/95 backdrop-blur border-b border-slate-200 sticky top-0 z-10">
  <div class="max-w-md mx-auto px-4 flex items-center justify-between h-14">
    <div class="flex items-center gap-2">
      <span class="text-xl">⚓</span>
      <span class="font-semibold text-slate-900">Marina</span>
    </div>
    <div class="flex items-center gap-1">
      <% nav_items.each do |label, path, active_for| %>
        <% active = active_for.call(request.path) %>
        <%= link_to label, path,
              class: "px-3 py-1.5 rounded-lg text-sm transition " +
                     (active ? "bg-blue-50 text-blue-700 font-medium" : "text-slate-600 hover:text-slate-900 hover:bg-slate-50") %>
      <% end %>
    </div>
  </div>
</nav>
