<% storage_color = boat.storage_type == "dry" ? "bg-amber-50 text-amber-800" : "bg-sky-50 text-sky-800" %>
<li class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
  <%= link_to boat_path(boat), class: "block p-4 hover:bg-slate-50 active:bg-slate-100 transition" do %>
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <h2 class="text-lg font-semibold text-slate-900 truncate"><%= boat.name %></h2>
        <% if boat.descriptor.present? && boat.descriptor != boat.name %>
          <p class="text-sm text-slate-500 truncate"><%= boat.descriptor %></p>
        <% end %>
      </div>
      <span class="text-blue-600 text-sm font-medium shrink-0">Details →</span>
    </div>
    <div class="mt-2 flex flex-wrap gap-1.5 text-xs">
      <span class="inline-flex items-center bg-slate-100 text-slate-700 px-2 py-0.5 rounded-full">
        📍 <%= boat.location.name %>
      </span>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full <%= storage_color %>">
        <%= boat.storage_type == "dry" ? "Dry storage" : "In water" %>
      </span>
      <% if boat.slip %>
        <span class="inline-flex items-center bg-slate-100 text-slate-700 px-2 py-0.5 rounded-full">
          Slip <%= boat.slip.label %>
        </span>
      <% end %>
    </div>

    <% if upcoming %>
      <div class="mt-3 flex items-center gap-2 text-sm bg-amber-50 text-amber-900 px-3 py-2 rounded-lg">
        <span><%= upcoming.request_type.icon %></span>
        <span class="font-medium"><%= upcoming.request_type.name %></span>
        <span class="text-amber-700">·</span>
        <span class="text-amber-700"><%= upcoming.in_tz.strftime("%a %l:%M %p").gsub("  ", " ") %></span>
        <span class="ml-auto"><%= render "shared/status_badge", status: upcoming.status %></span>
      </div>
    <% end %>
  <% end %>

  <div class="border-t border-slate-100 bg-slate-50/60 p-3">
    <%= link_to new_request_path(boat_id: boat.id),
          class: "flex items-center justify-center gap-1.5 w-full bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-medium py-2.5 rounded-xl text-sm transition" do %>
      <span>+</span><span>New service request</span>
    <% end %>
  </div>
</li>
