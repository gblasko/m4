<% content_for :title, "New request" %>
<div class="max-w-md mx-auto px-4 py-6 space-y-6">
  <div>
    <%= link_to "← #{@boat.name}", boat_path(@boat), class: "text-sm text-blue-600" %>
    <h1 class="text-2xl font-bold text-slate-900 mt-1">New request</h1>
    <p class="text-sm text-slate-500"><%= @boat.location.name %></p>
  </div>

  <% if @request.errors.any? %>
    <div class="bg-rose-50 text-rose-800 p-3 rounded text-sm">
      <%= @request.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= form_with model: @request, url: requests_path, local: true, class: "space-y-6" do |f| %>
    <%= hidden_field_tag "request[boat_id]", @boat.id %>

    <div>
      <div class="text-sm font-medium text-slate-700 mb-2">Service</div>
      <div class="grid grid-cols-2 gap-2">
        <% @types.each_with_index do |t, i| %>
          <label class="block cursor-pointer">
            <%= f.radio_button :request_type_id, t.id, required: true,
                  checked: @request.request_type_id == t.id || (i == 0 && @request.request_type_id.blank?),
                  class: "sr-only peer" %>
            <div class="border-2 border-slate-200 peer-checked:border-blue-500 peer-checked:bg-blue-50 rounded-xl p-3 text-center">
              <div class="text-2xl"><%= t.icon %></div>
              <div class="text-sm font-medium mt-1"><%= t.name %></div>
              <% if t.requires_description? %><div class="text-[10px] text-slate-500 mt-0.5">notes required</div><% end %>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <div data-controller="time-picker"
         data-time-picker-location-id-value="<%= @boat.location_id %>"
         data-time-picker-step-value="30"
         class="space-y-4">

      <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">Date</label>
        <input type="date"
               data-time-picker-target="date"
               data-action="change->time-picker#dateChanged"
               value="<%= @initial_date.to_s %>"
               min="<%= @min_date.to_s %>"
               max="<%= @max_date.to_s %>"
               class="w-full rounded-lg border border-slate-300 px-3 py-3 text-base">
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="text-sm font-medium text-slate-700">Time</label>
          <span class="text-xs text-slate-500" data-time-picker-target="hint">30-minute slots</span>
        </div>
        <div data-time-picker-target="slots"
             class="grid grid-cols-3 gap-2">
          <%= render "slot_buttons", slots: @initial_slots %>
        </div>
      </div>

      <%= f.hidden_field :scheduled_for, "data-time-picker-target": "selected" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Notes (optional unless service requires)</label>
      <%= f.text_area :description, rows: 3,
            class: "w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>

    <%= f.submit "Submit request",
          class: "w-full bg-blue-600 hover:bg-blue-700 disabled:bg-slate-300 text-white font-medium py-3 rounded-lg" %>
  <% end %>
</div>
