<%
  action = item[:action]
  changes = item[:changes] || {}
  to_status = changes["to"] || changes[:to]
  cfg = case action
        when "transition"
          case to_status
          when "in_progress" then { icon: "▶", bg: "bg-amber-100 text-amber-700", text: "started this request" }
          when "completed"   then { icon: "✓", bg: "bg-emerald-100 text-emerald-700", text: "marked this complete" }
          when "to_do"       then { icon: "↺", bg: "bg-slate-100 text-slate-600", text: "moved this back to To do" }
          when "cancelled"   then { icon: "×", bg: "bg-rose-100 text-rose-700", text: "cancelled this request" }
          end
        when "assign"
          assignee_id = changes["assigned_to_id"] || changes[:assigned_to_id]
          name = assignee_id ? User.find_by(id: assignee_id)&.name : nil
          if name
            { icon: "👤", bg: "bg-blue-50 text-blue-700", text: "assigned to #{name}" }
          else
            { icon: "👤", bg: "bg-slate-100 text-slate-600", text: "unassigned" }
          end
        when "staff_create"
          { icon: "📞", bg: "bg-blue-100 text-blue-700", text: "took this request from the customer" }
        end
%>
<% if cfg %>
  <li class="px-4 py-2 flex items-start gap-3 text-sm">
    <div class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-xs font-medium <%= cfg[:bg] %>"><%= cfg[:icon] %></div>
    <div class="min-w-0 flex-1">
      <div class="text-slate-700"><span class="font-medium text-slate-900"><%= item[:by]&.name || "System" %></span> <%= cfg[:text] %></div>
      <div class="text-xs text-slate-500"><%= item[:at].in_time_zone(location.timezone).strftime("%b %-d, %-l:%M %p") %></div>
    </div>
  </li>
<% end %>
