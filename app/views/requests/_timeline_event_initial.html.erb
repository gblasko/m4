<li class="px-4 py-2.5 flex items-start gap-3 text-sm">
  <div class="shrink-0 w-7 h-7 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center text-xs">+</div>
  <div class="min-w-0 flex-1">
    <div class="text-slate-800"><span class="font-medium"><%= req.customer.name %></span> submitted this request</div>
    <div class="text-xs text-slate-500"><%= req.created_at.in_time_zone(req.location.timezone).strftime("%b %-d, %-l:%M %p") %></div>
  </div>
</li>
