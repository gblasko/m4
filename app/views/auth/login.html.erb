<div class="bg-white rounded-2xl shadow-xl p-8">
  <div class="text-center mb-6">
    <div class="mx-auto w-12 h-12 rounded-full bg-blue-600 flex items-center justify-center text-white text-xl">⚓</div>
    <h1 class="mt-3 text-2xl font-bold text-slate-900">Marina Operations</h1>
    <p class="text-sm text-slate-500 mt-1">Enter your email or phone to sign in</p>
  </div>

  <%= form_with url: auth_create_token_path, local: true, class: "space-y-4" do |f| %>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Email or phone</label>
      <%= f.text_field :identifier, required: true, autofocus: true, autocomplete: "username",
            placeholder: "you@example.com or 555-123-4567",
            class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">
        Password <span class="text-slate-400 font-normal">(optional)</span>
      </label>
      <%= f.password_field :password, autocomplete: "current-password",
            placeholder: "Leave blank to receive a sign-in link",
            class: "w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      <p class="text-[11px] text-slate-500 mt-1">Most accounts use magic links. Admins may sign in with a password.</p>
    </div>
    <%= f.submit "Continue", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-lg transition" %>
  <% end %>

  <p class="text-xs text-center text-slate-400 mt-6">
    No account? Ask your marina to add you.
  </p>
</div>

<% if Rails.env.development? %>
  <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 mt-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-amber-900">Dev quick-login</h2>
      <span class="text-[10px] uppercase tracking-wide text-amber-700 bg-amber-200/60 px-2 py-0.5 rounded">development only</span>
    </div>
    <p class="text-xs text-amber-800 mb-3">Skip the magic-link flow. Available because <code>Rails.env.development?</code>.</p>
    <div class="grid grid-cols-3 gap-2">
      <% [["manager", "Manager", "bg-blue-600 hover:bg-blue-700"],
          ["helper",  "Helper",  "bg-teal-600 hover:bg-teal-700"],
          ["customer","Customer","bg-emerald-600 hover:bg-emerald-700"]].each do |role, label, color| %>
        <%= button_to label, dev_login_path(as: role), method: :post,
              class: "text-white text-sm font-medium py-2 rounded-lg #{color}",
              form: { class: "block" } %>
      <% end %>
    </div>
    <p class="text-[11px] text-amber-700 mt-3 leading-snug">
      Seeded users: <code>manager@example.com</code> · <code>helper@example.com</code> ·
      <code>customer@example.com</code> (has two boats).
      Run <code>bin/rails db:seed</code> if any are missing.
    </p>
  </div>
<% end %>
